<% if (page.total > 1) { %>
    <div class="pagination">
        <% if (page.prev) { %>
            <a href="<%- url_for(page.prev_link) %>"><i class="fa-solid fa-angle-left"></i></a>
        <% } %>
        <% if (page.next) { %>
            <a href="<%- url_for(page.next_link) %>"><i class="fa-solid fa-angle-right"></i>
            </a>
        <% } %>
    </div>
<% } %>
